# ── GitHub App ────────────────────────────────────────────────────────────────
# Required for GitHub repos. Create a GitHub App and install it on your org.
# https://docs.github.com/en/apps/creating-github-apps
GITHUB_CLIENT_ID=
GITHUB_APP_INSTALLATION_ID=
# Raw PEM private key content. Preserve newlines — do NOT base64-encode.
JWT_TOKEN=

# Optional: validate incoming GitHub PR webhooks (recommended in production)
GITHUB_WEBHOOK_SECRET=

# ── Bitbucket ─────────────────────────────────────────────────────────────────
# Required for Bitbucket repos. Create a Workspace Access Token in Bitbucket settings.
# Note: App Passwords are deprecated as of August 2025.
BITBUCKET_WORKSPACE_TOKEN=

# Optional: validate incoming Bitbucket PR webhooks (recommended in production)
BITBUCKET_WEBHOOK_SECRET=

# ── App ───────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
APP_WORKERS=1
APP_RELOAD=false
APP_ACCESS_LOGS=false

# 10=DEBUG, 20=INFO, 30=WARNING, 40=ERROR
LOG_LEVEL=20
